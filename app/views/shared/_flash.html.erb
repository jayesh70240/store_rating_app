<% if flash[:notice] %>
    <div style="color: green; background-color: #e6ffe6; padding: 10px; border: 1px solid green;">
    <%= flash.now[:notice] %>
    </div>
<% end %>

<% if flash[:alert] %>
    <div style="color: red; background-color: #ffe6e6; padding: 10px; border: 1px solid red;">
    <%= flash.now[:alert] %>
    </div>
<% end %>