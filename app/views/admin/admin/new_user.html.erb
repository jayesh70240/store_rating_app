<div class="container mt-5">
  <div class="card shadow-lg border-0">
    <div class="card-header bg-primary text-white">
      <h3 class="mb-0">User Registration</h3>
    </div>
    <div class="card-body">
      <%= form_with model: @user, url: admin_users_path, local: true do |form| %>
        <div class="row g-3 mb-3">
          <div class="col-md-6">
            <%= form.label :name, "Full Name", class: "form-label fw-bold" %>
            <%= form.text_field :name, class: "form-control", placeholder: "Enter full name" %>
          </div>
          <div class="col-md-6">
            <%= form.label :email, "Email Address", class: "form-label fw-bold" %>
            <%= form.email_field :email, class: "form-control", placeholder: "Enter email address" %>
          </div>
        </div>

        <div class="row g-3 mb-3">
          <div class="col-md-6">
            <%= form.label :password, "Password", class: "form-label fw-bold" %>
            <%= form.password_field :password, class: "form-control", placeholder: "Enter password" %>
          </div>
          <div class="col-md-6">
            <%= form.label :address, "Address", class: "form-label fw-bold" %>
            <%= form.text_field :address, class: "form-control", placeholder: "Enter address" %>
          </div>
        </div>

        <div class="row g-3 mb-4">
          <div class="col-md-6">
            <%= form.label :role, "Select Role", class: "form-label fw-bold" %>
            <%= form.select :role, User.roles.keys, {}, class: "form-select" %>
          </div>
        </div>

        <div class="text-end">
          <%= form.submit "Submit", class: "btn btn-success px-4 py-2" %>
          <%= link_to "Cancel", admin_users_path, class: "btn btn-outline-secondary px-4 py-2 ms-2" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
