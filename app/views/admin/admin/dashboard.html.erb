<div class="container mt-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Admin Dashboard</h2>
    <%= button_to "Logout", logout_path, method: :delete, class: "btn btn-danger px-4" %>
  </div>

  <div class="row g-4 mb-4">
    <div class="col-md-4">
      <div class="card text-white bg-primary shadow-sm">
        <div class="card-body">
          <h5 class="card-title">Total Users</h5>
          <p class="fs-3 fw-bold"><%= @total_users %></p>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card text-white bg-success shadow-sm">
        <div class="card-body">
          <h5 class="card-title">Total Stores</h5>
          <p class="fs-3 fw-bold"><%= @total_stores %></p>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card text-white bg-warning shadow-sm">
        <div class="card-body">
          <h5 class="card-title">Total Ratings</h5>
          <p class="fs-3 fw-bold"><%= @total_ratings %></p>
        </div>
      </div>
    </div>
  </div>

  <div class="row text-center">
    <div class="col-md-6 mb-3">
      <%= link_to 'Manage Users', admin_users_path, class: 'btn btn-primary btn-lg w-100 py-3 fw-bold shadow-sm' %>
    </div>
    <div class="col-md-6 mb-3">
      <%= link_to 'Manage Stores', admin_stores_path, class: 'btn btn-primary btn-lg w-100 py-3 fw-bold shadow-sm' %>
    </div>
  </div>
</div>
