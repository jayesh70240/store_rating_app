<div class="container d-flex justify-content-center align-items-center vh-100">
  <div class="card shadow-lg border-0 p-4" style="max-width: 500px; width: 100%;">
    <h2 class="text-center mb-4 text-primary fw-bold">Sign Up</h2>

    <%= form_with model: @user, url: signup_path, local: true do |f| %>
      <div class="form-group mb-3">
        <%= f.label :name, 'Full Name', class: 'form-label fw-semibold' %>
        <%= f.text_field :name, required: true, class: 'form-control', placeholder: 'Enter your full name' %>
      </div>
      
      <div class="form-group mb-3">
        <%= f.label :email, 'Email Address', class: 'form-label fw-semibold' %>
        <%= f.email_field :email, required: true, class: 'form-control', placeholder: 'Enter your email' %>
      </div>
      
      <div class="form-group mb-3">
        <%= f.label :address, 'Address', class: 'form-label fw-semibold' %>
        <%= f.text_field :address, class: 'form-control', placeholder: 'Enter your address' %>
      </div>
      
      <div class="form-group mb-3">
        <%= f.label :password, 'Password', class: 'form-label fw-semibold' %>
        <%= f.password_field :password, required: true, class: 'form-control', placeholder: 'Create a password' %>
      </div>
      
      <div class="form-group mb-4">
        <%= f.label :password_confirmation, 'Confirm Password', class: 'form-label fw-semibold' %>
        <%= f.password_field :password_confirmation, required: true, class: 'form-control', placeholder: 'Re-enter your password' %>
      </div>
      
      <div class="d-grid">
        <%= f.submit "Sign Up", class: 'btn btn-primary fw-bold py-2' %>
      </div>
    <% end %>

    <p class="text-center mt-3 mb-0">
      Already have an account? 
      <%= link_to 'Sign In', login_path, class: 'text-primary fw-semibold' %>
    </p>
  </div>
</div>
