<div class="d-flex justify-content-center align-items-center vh-100 bg-light">
  <div class="card shadow-lg p-4" style="max-width: 400px; width: 100%;">
    <h2 class="text-center mb-4">Login</h2>
    <%= form_with url: login_path, local: true do |f| %>
      <div class="mb-3">
        <%= f.label :email, class: 'form-label' %>
        <%= f.email_field :email, required: true, class: 'form-control', placeholder: 'Enter your email' %>
      </div>

      <div class="mb-3">
        <%= f.label :password, class: 'form-label' %>
        <%= f.password_field :password, required: true, class: 'form-control', placeholder: 'Enter your password' %>
      </div>

      <div class="d-grid mb-3">
        <%= f.submit "Login", class: 'btn btn-primary btn-lg' %>
      </div>
    <% end %>

    <div class="text-center">
      <%= link_to "Forgot Password?", '#', class: 'btn btn-link text-decoration-none' %>
    </div>
    <div class="text-center mt-2">
      <%= link_to "Don't have an account? Sign Up", signup_path, class: 'btn btn-link text-decoration-none' %>
    </div>
  </div>
</div>
